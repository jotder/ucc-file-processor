name: VOUCHER_UNKNOWN_ETL
version: 1

dirs:
  poll:       C:/sandbox/URA/sandbox/inbox/voucher/unknown
  database:   C:/sandbox/URA/sandbox/database/voucher
  backup:     C:/sandbox/URA/sandbox/backup/voucher_unknown
  temp:       C:/sandbox/URA/sandbox/temp/voucher_unknown
  errors:     C:/sandbox/URA/sandbox/errors/voucher_unknown
  quarantine: C:/sandbox/URA/sandbox/quarantine/voucher_unknown
  markers:    C:/sandbox/URA/sandbox/markers/voucher_unknown
  status_dir:  C:/sandbox/URA/sandbox/file-processor/status/voucher_unknown
  log_dir:     C:/sandbox/URA/sandbox/file-processor/logs/voucher_unknown

output:
  format: PARQUET
  compression: snappy

processing:
  threads: 4
  file_pattern: "glob:**/*.csv"
  duplicate_check:
    enabled: true
    marker_extension: .processed
    retention_days: 90
  schemas[3]{column_count,file_pattern,schema_file,table}:
    76,  "glob:**/*other*",    "C:/sandbox/URA/sandbox/file-processor/config/voucher/voucher_unknown_76.toon",  voucher_other
    116, "glob:**/*main*",     "C:/sandbox/URA/sandbox/file-processor/config/voucher/voucher_unknown_116.toon", voucher_main
    537, "",                   "C:/sandbox/URA/sandbox/file-processor/config/voucher/voucher_unknown_537.toon", voucher_cdr
  csv_settings:
    delimiter: ","
    skip_header_lines: 0
    skip_junk_lines: 0
    skip_tail_lines: 0
    skip_tail_columns: 0
    has_header: false
    date_formats[1]: "%Y%m%d"
    timestamp_formats[1]: "%Y%m%d"
