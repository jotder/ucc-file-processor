# Project exclude paths
# .claude/ IS tracked (shared team Claude Code setup: skills, agents, hooks, settings, maps) —
# only session-local and machine-local state stays ignored:
/.claude/settings.local.json
/.claude/sessions/
/.claude/worktrees/
/.claude/completions/
/.claude/templates/
/.idea/
/backup/
/database/
/errors/
/target/
/inspecto/target/
/inspecto-agent/target/
/inbox/
/markers/

# Build / run artifacts that must never be committed
*.class
*.log
*.dryrun

# IDE files (IntelliJ)
*.iml
/inspecto/.idea/

# Local build / deploy artifacts and ad-hoc run output
/file-processor-deploy.zip
/file-processor-deploy/
/file-processor-deploy-old/
/.graalvm-cache/
/file-processor-4.0/
/data/

# Scratch flow config + ad-hoc test-connection artifact
/inspecto/config/
/spaces/default/config/test_connection.toon

# Multi-space runtime output — keep spaces/<id>/config/ + space.toon tracked; ignore generated state.
/spaces/*/data/
/spaces/*/audit/
/spaces/*/duckdb/
/spaces/*/flows/

# Dry-run and audit outputs produced by ad-hoc local runs in the module root
/inspecto/available_files.csv*
/inspecto/missing_files.csv*
/inspecto/error_log.csv*
/inspecto/status_unknown.csv*
/inspecto-agent-hosted/target/

# Editor-local config (VS Code)
/.vscode/

# graphify knowledge-graph output (generated; regenerate with `graphify update .`)
graphify-out/

# Session-local working notes (*.local.* files are intentionally never committed)
*.local.md

# Stray npm lockfile at the repo root (no root package.json; the UI's lockfile
# lives in inspecto-ui/ and IS tracked)
/package-lock.json
/inspecto-issues/
