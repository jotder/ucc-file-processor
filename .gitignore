# Project exclude paths
/.claude/
/.idea/
/backup/
/database/
/errors/
/target/
/inspecto/target/
/inspecto-agent/target/
/inbox/
/markers/

# Build / run artifacts that must never be committed
*.class
*.log
*.dryrun

# IDE files (IntelliJ)
*.iml
/inspecto/.idea/

# Local build / deploy artifacts and ad-hoc run output
/file-processor-deploy.zip
/file-processor-4.0/
/data/

# Dry-run and audit outputs produced by ad-hoc local runs in the module root
/inspecto/available_files.csv*
/inspecto/missing_files.csv*
/inspecto/error_log.csv*
/inspecto/status_unknown.csv*
/inspecto-agent-hosted/target/

# Editor-local config (VS Code)
/.vscode/

# Session-local working notes (*.local.* files are intentionally never committed)
*.local.md

# Stray npm lockfile at the repo root (no root package.json; the UI's lockfile
# lives in inspecto-ui/ and IS tracked)
/package-lock.json
